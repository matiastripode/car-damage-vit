# Dominio principal de la app (web, api y mlflow por path)
APP_DOMAIN=your-domain.com

# Traefik Dashboard (ruta local: https://localhost/dashboard/)
# Formato htpasswd (usuario:hash). Generar, por ejemplo:
# htpasswd -nbB admin 'your-strong-password' | sed -e 's/\\$/\\$\\$/g'
TRAEFIK_DASHBOARD_AUTH=admin:$$2y$$05$$replace_with_real_htpasswd_hash

# Let's Encrypt (ACME) - deshabilitado temporalmente para entorno local.
# Descomentá cuando uses dominio público real.
# LETSENCRYPT_EMAIL=you@your-domain.com

# MinIO (acceso directo local, sin Traefik)
# API S3: http://localhost:9000
# Consola: http://localhost:9001
MINIO_ROOT_USER=your_minio_user
MINIO_ROOT_PASSWORD=your_minio_password
